{
  "name": "gym-tracker-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "check": "tsc --noEmit && npm run lint:fix",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "ANDROID_HOME=$HOME/Library/Android/sdk JAVA_HOME=$(/usr/libexec/java_home -v 17) expo run:android",
    "ios": "npm run openapi:ts; expo start --ios -c",
    "web": "expo start --web",
    "build": "npx expo prebuild --clean && npx expo run:ios",
    "xcode": "xed ios",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "lint:fix": "npx eslint  . --fix",
    "openapi:ts": "openapi-ts",
    "db:generate": "drizzle-kit generate",
    "db:drop": "drizzle-kit drop",
    "db:migrate": "drizzle-kit migrate"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "expo-sqlite-mock/src/setup.ts"
    ],
    "testTimeout": 10000
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@futurejj/react-native-visibility-sensor": "^1.4.13",
    "@hey-api/client-axios": "^0.7.0",
    "@kingstinct/react-native-healthkit": "^14.0.0",
    "@quidone/react-native-wheel-picker": "^1.7.0",
    "@quidone/react-native-wheel-picker-feedback": "^2.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli": "^20.1.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.14.5",
    "@tanstack/react-query": "^5.71.10",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "~55.0.8",
    "date-fns": "^4.3.0",
    "drizzle-orm": "^0.41.0",
    "expo": "~55.0.26",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.20",
