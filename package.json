{
  "name": "gym-tracker-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "check": "tsc --noEmit && npm run lint:fix",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "npm run openapi:ts; expo start --ios -c",
    "web": "expo start --web",
    "build": "npx expo prebuild --clean && npx expo run:ios",
    "xcode": "xed ios",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "lint:fix": "npx eslint  . --fix",
    "openapi:ts": "openapi-ts",
    "db:generate": "drizzle-kit generate",
    "db:drop": "drizzle-kit drop",
    "db:migrate": "drizzle-kit migrate"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "expo-sqlite-mock/src/setup.ts"
    ],
    "testTimeout": 10000
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@hey-api/client-axios": "^0.7.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/cli": "^20.1.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.14.5",
    "@tanstack/react-query": "^5.71.10",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-orm": "^0.41.0",
    "expo": "^55.0.6",
    "expo-blur": "^55.0.9",
    "expo-constants": "^55.0.7",
    "expo-dev-client": "^55.0.16",
    "expo-drizzle-studio-plugin": "^0.1.2",
    "expo-font": "^55.0.4",
    "expo-haptics": "^55.0.8",
    "expo-linking": "^55.0.7",
    "expo-router": "^55.0.5",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "^0.29.24",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~2.0.1",
    "expo-symbols": "~0.2.2",
    "expo-system-ui": "~4.0.8",
    "expo-web-browser": "~14.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "^0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.12.0",
    "react-native-ui-lib": "^8.3.4",
    "react-native-webview": "13.12.5",
    "uilib-native": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@hey-api/openapi-ts": "^0.66.7",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "drizzle-kit": "^0.30.5",
    "eslint-config-expo": "~8.0.1",
    "expo-module-scripts": "^4.0.4",
    "expo-sqlite-mock": "^2.2.0",
    "jest": "^29.2.1",
    "jest-expo": "^55.0.9",
    "react-test-renderer": "^19.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.30.1"
  },
  "private": true
}
